{
  "protocol": "FINAL",
  "method": "asyco_divmix",
  "dataset": "imbalanced",
  "optim": "sgd",
  "model": "resnet34_pretrained",
  "tau_train": 0.2,
  "tau_val": 0.0,
  "fold": 5,
  "fold_selection": "random.Random(10).randint(0, 9) -> 9",
  "n_trials": 22,
  "trial_epochs": 150,
  "tpe_seed": 42,
  "tpe_n_startup_trials": 15,
  "pruner": "MedianPruner",
  "pruner_n_startup_trials": 10,
  "pruner_n_warmup_steps": 30,
  "val_fraction": 0.15,
  "val_labels": "clean (loaded from tau=0.0 by image_id match)",
  "objective": "peak_smoothed_val_balanced_accuracy",
  "objective_smooth_window": 5,
  "pruning_enabled": true
}